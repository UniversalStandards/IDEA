# =============================================================
# Universal MCP Orchestration Hub — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================

# =========================================================
# Core Runtime
# =========================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Options: error | warn | info | http | verbose | debug | silly
# Note: 'silly' is blocked in NODE_ENV=production

# =========================================================
# Transport
# =========================================================
MCP_TRANSPORT=http
# Options: http | stdio | sse
# - http   : REST-only mode (no MCP transport attached)
# - stdio  : Attach MCP to stdin/stdout (CLI / Claude Desktop)
# - sse    : Attach MCP via Server-Sent Events at GET /mcp/sse

# =========================================================
# AI Routing
# =========================================================
DEFAULT_AI_PROVIDER=openai
FALLBACK_AI_PROVIDER=anthropic
LOCAL_MODEL_PROVIDER=ollama
ENABLE_MULTI_PROVIDER_ROUTING=true

# =========================================================
# Registry Sources
# =========================================================
ENABLE_GITHUB_REGISTRY=true
ENABLE_OFFICIAL_MCP_REGISTRY=true
ENABLE_ENTERPRISE_CATALOG=false
ENABLE_LOCAL_WORKSPACE_SCAN=true

# =========================================================
# GitHub / SCM
# =========================================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxx
GITHUB_REPO=your-org/universal-mcp-orchestration-hub
GITHUB_BRANCH=main

# =========================================================
# Security
# =========================================================
JWT_SECRET=replace_with_long_secure_value_at_least_32_chars
ENCRYPTION_KEY=replace_with_exactly_32_byte_hex_secret_here!
CORS_ORIGIN=*
# For production: CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com
ENABLE_SIGNATURE_VALIDATION=true
ENABLE_POLICY_ENGINE=true
REQUIRE_APPROVAL_FOR_HIGH_RISK_ACTIONS=true

# =========================================================
# Rate Limiting
# =========================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# =========================================================
# Enterprise Catalog (only when ENABLE_ENTERPRISE_CATALOG=true)
# =========================================================
ENTERPRISE_CATALOG_URL=
# ENTERPRISE_CATALOG_PATH=/path/to/catalog.json

# =========================================================
# Webhooks / Events Adapter
# =========================================================
WEBHOOK_SECRET=replace_with_hex_webhook_secret
EVENT_DEDUP_WINDOW_MS=300000

# =========================================================
# Cost Monitoring
# =========================================================
COST_TRACKING_ENABLED=true
COST_BUDGET_DAILY_USD=0
# Set to a positive number to enable daily budget alerts (0 = no limit)

# =========================================================
# Provisioning
# =========================================================
CACHE_TTL=3600
MAX_CONCURRENT_INSTALLS=5
ENABLE_AUTO_UPDATES=false
ENABLE_RUNTIME_HEALTH_RECOVERY=true

# =========================================================
# Redis (optional — for future distributed caching mode)
# =========================================================
REDIS_URL=
# Example: REDIS_URL=redis://localhost:6379

# =========================================================
# Observability
# =========================================================
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_AUDIT_LOGGING=true
