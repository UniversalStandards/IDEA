# =============================================================
# Universal MCP Orchestration Hub — .gitignore
# =============================================================

# Build output
dist/
.tsbuildinfo
*.tsbuildinfo

# Dependencies
node_modules/

# Environment — never commit secrets
.env
.env.local
.env.*.local
!.env.example

# Test & Coverage
coverage/
*.lcov
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data — generated at process start, should not be committed
runtime/
cache/
plugins/

# Audit log (written by audit.ts at runtime)
audit.log
audit.jsonl
workflow-dlq.jsonl

# Secrets (never commit encrypted credential files)
secrets.enc
*.pem
*.key
*.p12
*.pfx

# OS artifacts
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Package managers
.npm/
.pnpm-store/
.yarn/
!.yarn/releases
!.yarn/plugins

# Temporary
tmp/
temp/
*.tmp
*.temp

# Docker
.docker/

# Website build artifacts
website/.next/
website/node_modules/
website/out/
